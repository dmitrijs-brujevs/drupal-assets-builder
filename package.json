{
  "name": "drupal-assets-builder",
  "version": "1.1.0",
  "description": "A single Vite-based asset builder for custom modules and themes in Drupal projects.",
  "type": "module",
  "license": "MIT",
  "author": "Dmitrijs Brujevs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmitrijs-brujevs/drupal-assets-builder.git"
  },
  "bugs": {
    "url": "https://github.com/dmitrijs-brujevs/drupal-assets-builder/issues"
  },
  "homepage": "https://github.com/dmitrijs-brujevs/drupal-assets-builder#readme",
  "engines": {
    "node": ">=22.14.0"
  },
  "packageManager": "npm@11.5.1",
  "bin": {
    "drupal-assets": "bin/drupal-assets.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "eslint.config.js",
    "stylelint.config.js"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "drupal",
    "vite",
    "assets",
    "sass",
    "scss",
    "frontend",
    "modules",
    "themes",
    "asset-builder"
  ],
  "scripts": {
    "build": "node scripts/build-fixture.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "lint": "eslint . && stylelint \"{src,test,fixtures}/**/*.scss\"",
    "lint:fix": "eslint . --fix && stylelint \"{src,test,fixtures}/**/*.scss\" --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "validate:package": "node scripts/validate-package.js",
    "check": "npm test && npm run lint && npm run format && npm run build && npm run validate:package"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "chokidar": "^5.0.0",
    "eslint": "^10.4.1",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "lightningcss": "^1.32.0",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.3",
    "resolve.exports": "^2.0.3",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^8.0.16",
    "vite-plugin-full-reload": "^1.2.0"
  }
}
